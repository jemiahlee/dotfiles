#!/bin/bash +x

TEMPFILE=$(mktemp)

COMMAND=$1
ORIGINAL_FILE=$2

`$HOME/bin/bak ${ORIGINAL_FILE}`

echo "${COMMAND} ${ORIGINAL_FILE} > ${TEMPFILE}"
`${COMMAND} ${ORIGINAL_FILE} > ${TEMPFILE}`

if [ $? -ne 0 ]; then
  echo "Error running initial command, not copying over the original file"
else
  echo "mv ${TEMPFILE} ${ORIGINAL_FILE}"
  `mv ${TEMPFILE} ${ORIGINAL_FILE}`
fi
